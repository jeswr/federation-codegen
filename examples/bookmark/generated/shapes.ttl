@prefix book: <https://w3id.org/jeswr/bookmark#>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix schema: <http://schema.org/>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix shapes: <https://w3id.org/jeswr/bookmark/shapes#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

shapes:Bookmark-archived sh:datatype xsd:boolean;
    sh:maxCount 1;
    sh:name "archived";
    sh:path book:archived.
shapes:Bookmark-created sh:datatype xsd:dateTime;
    sh:maxCount 1;
    sh:name "created";
    sh:path dct:created.
shapes:Bookmark-description sh:datatype xsd:string;
    sh:maxCount 1;
    sh:name "description";
    sh:path dct:description.
shapes:Bookmark-keywords sh:datatype xsd:string;
    sh:name "tags";
    sh:path schema:keywords.
shapes:Bookmark-modified sh:datatype xsd:dateTime;
    sh:maxCount 1;
    sh:name "modified";
    sh:path dct:modified.
shapes:Bookmark-notes sh:datatype xsd:string;
    sh:maxCount 1;
    sh:name "notes";
    sh:path book:notes.
shapes:Bookmark-title sh:datatype xsd:string;
    sh:maxCount 1;
    sh:name "title";
    sh:path dct:title.
shapes:Bookmark-url sh:maxCount 1;
    sh:minCount 1;
    sh:name "url";
    sh:nodeKind sh:IRI;
    sh:path schema:url;
    sh:pattern "^https?://".
shapes:BookmarkShape a sh:NodeShape;
    sh:property shapes:Bookmark-archived, shapes:Bookmark-created, shapes:Bookmark-description, shapes:Bookmark-keywords, shapes:Bookmark-modified, shapes:Bookmark-notes, shapes:Bookmark-title, shapes:Bookmark-url;
    sh:targetClass book:Bookmark.
