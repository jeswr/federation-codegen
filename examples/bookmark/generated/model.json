{
  "manifestVersion": 1,
  "runtime": {
    "name": "@jeswr/model-runtime",
    "major": 0
  },
  "prefixes": {
    "book": "https://w3id.org/jeswr/bookmark#",
    "schema": "http://schema.org/",
    "dct": "http://purl.org/dc/terms/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "entities": [
    {
      "name": "Bookmark",
      "typeIris": [
        "https://w3id.org/jeswr/bookmark#Bookmark"
      ],
      "subject": {
        "convention": "hash-it"
      },
      "fields": [
        {
          "name": "created",
          "predicate": "http://purl.org/dc/terms/created",
          "kind": "literal",
          "datatype": "http://www.w3.org/2001/XMLSchema#dateTime",
          "maxCount": 1,
          "defaultNow": true,
          "guards": {}
        },
        {
          "name": "description",
          "predicate": "http://purl.org/dc/terms/description",
          "kind": "literal",
          "datatype": "http://www.w3.org/2001/XMLSchema#string",
          "maxCount": 1,
          "guards": {
            "emptyStringDrop": true
          }
        },
        {
          "name": "modified",
          "predicate": "http://purl.org/dc/terms/modified",
          "kind": "literal",
          "datatype": "http://www.w3.org/2001/XMLSchema#dateTime",
          "maxCount": 1,
          "guards": {}
        },
        {
          "name": "title",
          "predicate": "http://purl.org/dc/terms/title",
          "kind": "literal",
          "datatype": "http://www.w3.org/2001/XMLSchema#string",
          "maxCount": 1,
          "guards": {
            "emptyStringDrop": true
          }
        },
        {
          "name": "tags",
          "predicate": "http://schema.org/keywords",
          "kind": "literal",
          "collection": "set",
          "datatype": "http://www.w3.org/2001/XMLSchema#string",
          "guards": {
            "trim": true,
            "dropBlank": true,
            "sortOnRead": true
          }
        },
        {
          "name": "url",
          "predicate": "http://schema.org/url",
          "kind": "iri",
          "minCount": 1,
          "maxCount": 1,
          "guards": {
            "iriScheme": "http-https",
            "requiredFailClosed": true
          }
        },
        {
          "name": "archived",
          "predicate": "https://w3id.org/jeswr/bookmark#archived",
          "kind": "literal",
          "datatype": "http://www.w3.org/2001/XMLSchema#boolean",
          "maxCount": 1,
          "default": false,
          "materializeDefault": true,
          "guards": {}
        },
        {
          "name": "notes",
          "predicate": "https://w3id.org/jeswr/bookmark#notes",
          "kind": "literal",
          "datatype": "http://www.w3.org/2001/XMLSchema#string",
          "maxCount": 1,
          "guards": {
            "emptyStringDrop": true
          }
        }
      ]
    }
  ]
}
